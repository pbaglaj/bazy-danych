{
  "name": "superhero-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node app.js",
    "migrate": "sequelize db:migrate --config db/config/config.js --migrations-path db/migrations",
    "migrate:rollback": "sequelize db:migrate:undo:all --config db/config/config.js --migrations-path db/migrations",
    "seed": "sequelize db:seed:all --config db/config/config.js --seeders-path db/seeds/development",
    "seed:test": "cross-env NODE_ENV=test sequelize db:seed:all --config db/config/config.js --seeders-path db/seeds/test",
    "db:reset": "npm run migrate:rollback && npm run migrate && npm run seed",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.19.0",
    "sequelize": "^6.37.7"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "cross-env": "^7.0.3",
    "sequelize-cli": "^6.6.3"
  }
}
